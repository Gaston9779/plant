# Backend URL used by the mobile app pipeline
EXPO_PUBLIC_BACKEND_URL=http://192.168.1.10:8080

# Hugging Face auth token (shared by both HF models)
EXPO_PUBLIC_HUGGINGFACE_TOKEN=

# Hugging Face biological classifier model (image -> species)
# Example format: owner/model-name
EXPO_PUBLIC_HF_BIO_MODEL=
EXPO_PUBLIC_HF_SPECIES_MODEL=

# Hugging Face historical model (text -> plant history paragraph)
# Example format: owner/model-name
EXPO_PUBLIC_HF_HISTORY_MODEL=

# Hugging Face narrative model (optional, JSON sections generation)
EXPO_PUBLIC_HF_NARRATIVE_MODEL=meta-llama/Llama-3.1-8B-Instruct

# Hugging Face disease model (optional, image -> disease label)
EXPO_PUBLIC_HF_DISEASE_MODEL=

# Optional fallback real classifier (PlantNet)
EXPO_PUBLIC_PLANTNET_API_KEY=
